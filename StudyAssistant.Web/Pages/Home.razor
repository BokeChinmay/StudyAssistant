@page "/"
@inject HttpClient Http
@using Markdig
@using StudyAssistant.Web.Models
@using StudyAssistant.Web.Services
@using StudyAssistant.Web.Components

<div class="chat-wrap">
    <div class="stats-bar">
        <span class="stat"><i>💬</i> @_stats.MessageCount msgs</span>
        <span class="stat"><i>🃏</i> @_stats.FlashcardSets sets</span>
        <span class="stat"><i>🎯</i> @_stats.QuizCorrect / @_stats.QuizTotal quiz</span>
        <span class="mode-badge mode-@_stats.ActiveMode.ToLower()">@_stats.ActiveMode</span>
    </div>

    <div class="upload-bar">
    <label class="upload-label">
        <i class="upload-icon">📎</i>
        <span>@(_uploading ? "Uploading..." : "Upload notes (.pdf or .txt)")</span>
        <InputFile OnChange="HandleUpload" accept=".pdf,.txt" disabled="@_uploading" style="display:none" />
    </label>
    @if (_documents.Count > 0)
    {
        <div class="doc-pills">
            @foreach (var doc in _documents)
            {
                <span class="doc-pill">@doc</span>
            }
        </div>
    }
    @if (!string.IsNullOrEmpty(_uploadMessage))
    {
        <span class="upload-msg">@_uploadMessage</span>
    }
</div>

    <div class="mode-hints">
        <span class="hint">explain a concept</span>
        <span class="hint">make flashcards on [topic]</span>
        <span class="hint">quiz me on [topic]</span>
    </div>

    <div class="messages" id="msgList">
        @foreach (var msg in _messages)
        {
            <div class="msg @msg.Role">
                @if (msg.DeckState != null)
                {
                    <FlashcardDeck State="msg.DeckState"
                                   OnStateChanged="s => { msg.DeckState = s; StateHasChanged(); }" />
                }
                else
                {
                    <div class="bubble">
                        @if (msg.Role == "assistant")
                        {
                            @((MarkupString)RenderMarkdown(msg.Content))
                        }
                        else
                        {
                            @msg.Content
                        }
                    </div>
                }
            </div>
        }
        @if (!string.IsNullOrEmpty(_streamBuffer))
        {
            <div class="msg assistant">
                <div class="bubble">@((MarkupString)RenderMarkdown(_streamBuffer))</div>
            </div>
        }
        @if (_isStreaming && string.IsNullOrEmpty(_streamBuffer))
        {
            <div class="msg assistant">
                <div class="bubble thinking">thinking…</div>
            </div>
        }
    </div>

    <div class="input-row">
        <input @bind="_input"
               @bind:event="oninput"
               @onkeydown="HandleKey"
               placeholder="Ask me to explain, make flashcards, or quiz you…"
               disabled="@_isStreaming" />
        <button @onclick="SendMessage" disabled="@_isStreaming">
            @(_isStreaming ? "…" : "Send")
        </button>
    </div>
</div>

@code {
    private string _input = "";
    private string _streamBuffer = "";
    private bool _isStreaming = false;
    private string _sessionId = Guid.NewGuid().ToString();
    private List<ChatMessage> _messages = new();
    private SessionStats _stats = new();
    private bool _uploading = false;
    private string _uploadMessage = "";
    private List<string> _documents = new();

    private string RenderMarkdown(string text)
    {
        var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
        return Markdown.ToHtml(text, pipeline);
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_input) || _isStreaming) return;

        var userMsg = _input.Trim();
        _messages.Add(new ChatMessage("user", userMsg));
        _input = "";
        _isStreaming = true;
        _streamBuffer = "";
        StateHasChanged();

        try
        {
            var payload = new { Message = userMsg, SessionId = _sessionId };

            using var request = new HttpRequestMessage(HttpMethod.Post, "api/chat/stream")
            {
                Content = JsonContent.Create(payload)
            };

            using var response = await Http.SendAsync(
                request, HttpCompletionOption.ResponseHeadersRead);
            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line?.StartsWith("data: ") != true) continue;

                var token = line[6..];
                if (token == "[DONE]") break;

                _streamBuffer += token.Replace("\\n", "\n");
                StateHasChanged();
            }

            if (!string.IsNullOrEmpty(_streamBuffer))
            {
                // Detect flashcard responses and swap to deck component
                if (FlashcardParser.IsFlashcardResponse(_streamBuffer))
                {
                    var cards = FlashcardParser.Parse(_streamBuffer);
                    if (cards.Count > 0)
                    {
                        var deck = new FlashcardDeckState();
                        deck.Cards.AddRange(cards);
                        _messages.Add(new ChatMessage("assistant", _streamBuffer, deck));
                    }
                    else
                    {
                        _messages.Add(new ChatMessage("assistant", _streamBuffer));
                    }
                }
                else
                {
                    _messages.Add(new ChatMessage("assistant", _streamBuffer));
                }
            }

            await RefreshStats();
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage("assistant", $"[Error: {ex.Message}]"));
        }
        finally
        {
            _streamBuffer = "";
            _isStreaming = false;
            StateHasChanged();
        }
    }

    private async Task RefreshStats()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<SessionStats>(
                $"api/stats/{_sessionId}");
            if (result != null) _stats = result;
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandleUpload(InputFileChangeEventArgs e) {
        _uploading = true;
        _uploadMessage = "";
        StateHasChanged();

        try {
            var file = e.File;
            var maxSize= 10 * 1024 * 1024; // 10 MB limit

            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            content.Add(new StringContent(_sessionId), "sessionId");
            content.Add(new StreamContent(ms), "file", file.Name);

            var response = await Http.PostAsync("api/document/upload", content);

            if(response.IsSuccessStatusCode) {
                _uploadMessage = $"✓ {file.Name} ready";
                await RefreshDocuments();
            }
            else {
                var error = await response.Content.ReadAsStringAsync();
                _uploadMessage = $"✗ {error}";
            }
        }
        catch (Exception ex) {
            _uploadMessage = $"✗ {ex.Message}";
        }
        finally {
            _uploading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDocuments() {
        try {
            var docs = await Http.GetFromJsonAsync<List<string>>($"api/document/list/{_sessionId}");
            if (docs != null) _documents = docs;
            StateHasChanged();
        }
        catch { }
    }

    private class ChatMessage
    {
        public string Role { get; }
        public string Content { get; }
        public FlashcardDeckState? DeckState { get; set; }

        public ChatMessage(string role, string content, FlashcardDeckState? deck = null)
        {
            Role = role;
            Content = content;
            DeckState = deck;
        }
    }

    private class SessionStats
    {
        public int MessageCount { get; set; }
        public int QuizCorrect { get; set; }
        public int QuizTotal { get; set; }
        public int FlashcardSets { get; set; }
        public string ActiveMode { get; set; } = "General";
    }
}