@page "/about"

<div class="about-wrap">
    <h1>AI Study Assistant</h1>
    <p class="about-sub">
        A full-stack AI study tool built with ASP.NET Core, Blazor WebAssembly,
        and a from-scratch RAG pipeline.
    </p>

    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-icon">💬</div>
            <div class="feature-title">AI Chat</div>
            <div class="feature-desc">Streaming responses with full conversation memory using Groq's Llama 3.3 model.</div>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🃏</div>
            <div class="feature-title">Flashcards</div>
            <div class="feature-desc">Auto-generated interactive flip cards with review marking from any topic.</div>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🎯</div>
            <div class="feature-title">Quiz Mode</div>
            <div class="feature-desc">Adaptive quizzing with score tracking and session statistics.</div>
        </div>
        <div class="feature-card">
            <div class="feature-icon">📄</div>
            <div class="feature-title">RAG Pipeline</div>
            <div class="feature-desc">Upload your own notes - the AI answers directly from your documents using vector similarity search.</div>
        </div>
    </div>

    <div class="tech-section">
        <h2>Tech stack</h2>
        <div class="tech-pills">
            <span class="tech-pill">ASP.NET Core 8</span>
            <span class="tech-pill">Blazor WebAssembly</span>
            <span class="tech-pill">C#</span>
            <span class="tech-pill">Groq API</span>
            <span class="tech-pill">Ollama Embeddings</span>
            <span class="tech-pill">Cosine Similarity Search</span>
            <span class="tech-pill">PdfPig</span>
            <span class="tech-pill">Markdig</span>
            <span class="tech-pill">Server-Sent Events</span>
        </div>
    </div>
</div>